# =============================================================================
# Legalyx CMS - Variables d'environnement
# =============================================================================
# Copiez ce fichier en .env.local et remplissez avec vos valeurs Supabase
# cp .env.example .env.local
# =============================================================================

# Supabase - Trouvez ces valeurs dans votre tableau de bord Supabase
# Settings > API > Project URL
NEXT_PUBLIC_SUPABASE_URL=https://votre-projet.supabase.co

# Settings > API > anon (public) key
NEXT_PUBLIC_SUPABASE_ANON_KEY=votre-anon-key-ici

# Settings > API > service_role (secret) key
# Requis pour la création d'utilisateurs par l'admin
# NE JAMAIS exposer côté client (pas de NEXT_PUBLIC_ prefix)
SUPABASE_SERVICE_ROLE_KEY=votre-service-role-key-ici